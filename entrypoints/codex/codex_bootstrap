#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from codex_support import build_command, output_tail, run_with_pty  # noqa: E402


SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {"ok": {"type": "boolean"}},
    "required": ["ok"],
}


def bootstrap_workspace(workspace: Path) -> int:
    with tempfile.TemporaryDirectory(prefix="nk-codex-bootstrap-") as temp:
        temp_path = Path(temp)
        schema_path = temp_path / "schema.json"
        result_path = temp_path / "result.json"
        schema_path.write_text(json.dumps(SCHEMA), encoding="utf-8")
        command = build_command('Return exactly {"ok": true}.')
        command[-1:-1] = ["--output-schema", str(schema_path), "-o", str(result_path)]
        completed = run_with_pty(command, sys.stdout.buffer, cwd=workspace)
        if completed.returncode != 0:
            print(f"{workspace}: ERROR")
            if completed.stderr:
                print(output_tail(completed.stderr), file=sys.stderr)
            return completed.returncode
        if not result_path.exists():
            print(f"{workspace}: ERROR: no result file")
            return 1
        print(f"{workspace}: OK")
        return 0


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: codex_bootstrap WORKSPACE [...]", file=sys.stderr)
        return 2
    exit_code = 0
    for item in sys.argv[1:]:
        exit_code = max(exit_code, bootstrap_workspace(Path(item).resolve()))
    return exit_code


if __name__ == "__main__":
    raise SystemExit(main())
